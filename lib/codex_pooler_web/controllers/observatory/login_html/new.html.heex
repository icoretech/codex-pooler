<Layouts.app flash={@flash} auth_surface>
  <section
    id="observatory-login"
    class="mx-auto grid min-h-[calc(100svh-10rem)] w-full max-w-xl items-center px-4 py-10"
  >
    <div class="border border-base-300 bg-base-100 p-6 shadow-2xl shadow-base-content/10 sm:p-8">
      <Layouts.public_logo id="observatory-login-logo" />
      <p class="mt-6 font-mono text-xs font-semibold uppercase tracking-[0.28em] text-primary">
        Observatory
      </p>
      <h1 class="mt-3 text-3xl font-black tracking-[-0.06em] text-base-content sm:text-5xl">
        Continue to the Observatory
      </h1>
      <p class="mt-4 text-sm leading-6 text-base-content/70">
        Enter your access key to continue.
      </p>
      <p
        :if={@error}
        id="observatory-login-error"
        class="mt-5 rounded border border-error/30 bg-error/10 px-3 py-2 text-sm text-error"
      >
        {@error}
      </p>

      <.form
        for={@form}
        id="observatory-login-form"
        action={~p"/observatory/login"}
        method="post"
        class="mt-8 grid gap-5"
      >
        <.input
          field={@form[:api_key]}
          id="observatory-api-key"
          type="password"
          label="Access key"
          autocomplete="current-password"
          required
        />
        <.button id="observatory-login-submit" class="btn btn-primary w-full">
          Continue
        </.button>
      </.form>
    </div>
  </section>
</Layouts.app>
