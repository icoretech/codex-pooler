<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Codex Pooler" suffix={live_title_suffix(assigns[:page_title])}>
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" href={~p"/favicon.ico"} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={~p"/favicon-32x32.png"} />
    <link rel="icon" type="image/png" sizes="16x16" href={~p"/favicon-16x16.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/site.webmanifest"} />
    <meta name="theme-color" content="#ff9900" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        const storedTheme = localStorage.getItem("phx:theme");
        const isObservatoryPath = window.location.pathname === "/observatory" ||
          window.location.pathname.startsWith("/observatory/");
        if (!document.documentElement.hasAttribute("data-theme")) {
          if (storedTheme) {
            setTheme(storedTheme);
          } else if (isObservatoryPath) {
            document.documentElement.setAttribute("data-theme", "dark");
          } else {
            setTheme("system");
          }
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
    <.impeccable_live_script />
  </body>
</html>
