# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix coverage" or "mix six", coverage assets end up here.
/.six/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/
/tmp/mcp-smoke/

# Local automation artifacts.
AGENTS.md
DESIGN.md
PRODUCT.md
RUNBOOK.md
/docs/
/scripts/restore.sh
/scripts/*.dump
/scripts/*.sql
/scripts/*.sql.gz
/scripts/dev/
/scripts/smoke/
/.agents/
/.kilo/
/.codex/
/.playwright-mcp/
/.sisyphus/
/.desloppify/
/.elixir_ls/
/.impeccable/
/.omo/
/.omp/
.codegraphignore
/references/*
!/references/.gitkeep
!/references/README.md

# Local app-private runtime file payloads.
/var/codex_pooler/files/

# Ignore package tarball (built via "mix hex.build").
codex_pooler-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/
/priv/static/cache_manifest.json
/priv/static/**/*.gz
/priv/static/**/*-[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].*

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Generated docs-site artifacts.
docs-site/node_modules/
docs-site/dist/
docs-site/.astro/
# macOS Finder metadata.
.DS_Store

# Local environment files. Keep .env.example tracked.
.env*
!.env.example
!.env.dev.example
__pycache__/
.desloppify/
scorecard.png
.omo/
output/imagegen/
.claude/
